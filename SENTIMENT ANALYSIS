import pandas as pd
import re
import nltk
import matplotlib.pyplot as plt
from nltk.tokenize import word_tokenize
from nltk.corpus import stopwords
from nltk.stem import PorterStemmer
from textblob import TextBlob


nltk.download('punkt')
nltk.download('punkt_tab', quiet=True)   # kept as you wanted, but safely handled
nltk.download('stopwords')


url = "https://raw.githubusercontent.com/dD2405/Twitter_Sentiment_Analysis/master/train.csv"
data = pd.read_csv(url)
data = data[['label', 'tweet']]
data.rename(columns={'tweet': 'review'}, inplace=True)
data.head()


def clean(text):
    text = re.sub('[^a-zA-Z]', ' ', str(text))
    text = text.lower()
    return text
data['clean_text'] = data['review'].apply(clean)


data['tokens'] = data['clean_text'].apply(word_tokenize)


stop_words = set(stopwords.words('english'))
data['tokens'] = data['tokens'].apply(
    lambda words: [word for word in words if word not in stop_words]
)


stemmer = PorterStemmer()
data['stemmed'] = data['tokens'].apply(
    lambda words: [stemmer.stem(word) for word in words]
)


def get_sentiment(text):
    analysis = TextBlob(str(text))
    polarity = analysis.sentiment.polarity
    if polarity > 0:
        return "Positive"
    elif polarity < 0:
        return "Negative"
    else:
        return "Neutral"


data['sentiment'] = data['review'].apply(get_sentiment)
data[['review', 'sentiment']].head()


data['sentiment'].value_counts().plot(kind='bar')
plt.title("Sentiment Distribution")
plt.xlabel("Sentiment")
plt.ylabel("Count")
plt.show()
